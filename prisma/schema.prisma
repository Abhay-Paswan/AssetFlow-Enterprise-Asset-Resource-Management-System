// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  password     String
  name         String
  role         String      @default("Employee") // Admin, Asset Manager, Department Head, Employee
  status       String      @default("Active") // Active, Inactive
  departmentId String?
  department   Department? @relation("DepartmentMembers", fields: [departmentId], references: [id])
  headedDept   Department? @relation("DepartmentHead")
  bookings     Booking[]
  maintenanceRequests MaintenanceRequest[]
  auditedCycles AuditCycle[] @relation("AuditCycleAuditors")
  activityLogs  ActivityLog[]
  notifications Notification[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Department {
  id        String       @id @default(uuid())
  name      String
  headId    String?      @unique
  head      User?        @relation("DepartmentHead", fields: [headId], references: [id])
  parentId  String?
  parent    Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children  Department[] @relation("DepartmentHierarchy")
  status    String       @default("Active") // Active, Inactive
  members   User[]       @relation("DepartmentMembers")
  assets    Asset[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model Category {
  id               String   @id @default(uuid())
  name             String
  customAttributes String   // JSON stringified key-value array
  assets           Asset[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Asset {
  id               String       @id @default(uuid())
  name             String
  tag              String       @unique // auto-generated Asset Tag AF-XXXX
  categoryId       String
  category         Category     @relation(fields: [categoryId], references: [id])
  departmentId     String?
  department       Department?  @relation(fields: [departmentId], references: [id])
  serialNumber     String?
  acquisitionDate  DateTime?
  acquisitionCost  Float?
  condition        String       // 'New' | 'Good' | 'Fair' | 'Poor'
  location         String?
  imageUrl         String?
  isSharedResource Boolean      @default(false)
  status           String       @default("Available") // 'Available' | 'Allocated' | 'Reserved' | 'Under Maintenance' | 'Lost' | 'Retired' | 'Disposed'
  
  allocations      Allocation[]
  transferRequests TransferRequest[]
  bookings         Booking[]
  maintenanceRequests MaintenanceRequest[]
  auditItems          AuditItem[]
  
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Allocation {
  id                 String    @id @default(uuid())
  assetId            String
  asset              Asset     @relation(fields: [assetId], references: [id])
  assigneeId         String    // UserId or DepartmentId
  expectedReturnDate DateTime?
  returnedDate       DateTime?
  checkInNotes       String?   // 'Good' | 'Damaged' | 'Needs Repair'
  status             String    @default("Allocated") // 'Allocated' | 'Returned'
  
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model TransferRequest {
  id                 String   @id @default(uuid())
  assetId            String
  asset              Asset    @relation(fields: [assetId], references: [id])
  fromUserId         String?  // user releasing it
  toUserId           String   // user requesting it
  status             String   @default("Requested") // 'Requested' | 'Approved' | 'Rejected'
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Booking {
  id         String   @id @default(uuid())
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  startTime  DateTime
  endTime    DateTime
  purpose    String
  status     String   @default("Upcoming") // 'Upcoming' | 'Ongoing' | 'Completed' | 'Cancelled'
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model MaintenanceRequest {
  id          String   @id @default(uuid())
  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  issue       String
  priority    String   // 'Low' | 'Medium' | 'High'
  photoUrl    String?
  status      String   @default("Pending") // 'Pending' | 'Approved' | 'Rejected' | 'Technician Assigned' | 'In Progress' | 'Resolved'
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditCycle {
  id          String   @id @default(uuid())
  name        String
  startDate   DateTime
  endDate     DateTime
  status      String   @default("Active") // 'Active' | 'Closed'
  scopeType   String   // 'Department' | 'Location'
  scopeValue  String   // e.g., departmentId or location string
  
  auditors    User[]   @relation("AuditCycleAuditors")
  items       AuditItem[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditItem {
  id            String     @id @default(uuid())
  auditCycleId  String
  auditCycle    AuditCycle @relation(fields: [auditCycleId], references: [id])
  assetId       String
  asset         Asset      @relation(fields: [assetId], references: [id])
  status        String     @default("Pending") // 'Pending' | 'Verified' | 'Missing' | 'Damaged'
  notes         String?
  
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  action      String
  entityType  String
  entityId    String
  message     String
  
  createdAt   DateTime @default(now())
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  message     String
  type        String   // 'Alert' | 'Info' | 'Warning' | 'Success'
  isRead      Boolean  @default(false)
  link        String?
  
  createdAt   DateTime @default(now())
}
